# Project Name
spring.application.name=kineticvault-backend
server.port=8080

# MongoDB Atlas
# Replace with your connection string
spring.mongodb.uri=mongodb+srv://<username>:<password>@cluster0.umjoudg.mongodb.net/kineticvault?appName=Cluster0
spring.data.mongodb.auto-index-creation=true

# Gemini API
# Replace with your Gemini API key from Google AI Studio
gemini.api.key=YOUR_API_KEY_HERE
gemini.api.base-url=https://generativelanguage.googleapis.com
gemini.api.version=v1
gemini.api.model=gemini-2.5-flash

# File Upload
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# Tesseract
tesseract.data.path=tessdata

# CORS
app.cors.allowed-origins=*
